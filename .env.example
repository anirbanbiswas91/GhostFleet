# GhostFleet environment variables
# Copy this file to .env and adjust as needed. Do not commit real secrets.

# Node environment: development | production
NODE_ENV=development

# HTTP port the server listens on
PORT=3000

# Serve only the free tier (premium routes/APIs return disabled responses).
# Set to true for the Railway free-only production deployment.
GHOSTFLEET_FREE_ONLY=false

# Payment milestone flags. Stripe billing routes are currently stubbed; these
# are reserved for the future payment milestone.
PAYMENTS_ENABLED=false
PREMIUM_OPEN_ACCESS=true

# Stripe keys are reserved for the future payment milestone. Leave blank locally.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public base URL of the deployment. Reserved for future outbound links and
# billing callbacks; validated at startup for consistency.
PUBLIC_BASE_URL=http://localhost:3000

# Optional asset cache-busting override. If unset, deploy metadata or file mtimes
# are used for /shared/game.css and /shared/game.js versions.
GHOSTFLEET_ASSET_VERSION=

# Optional: comma-separated extra Socket.IO allowed origins, in addition to the
# built-in localhost / ghostfleet.in / *.railway.app defaults.
GHOSTFLEET_SOCKET_ORIGINS=

# Optional multiplayer timing overrides (milliseconds). Defaults applied if unset.
GHOSTFLEET_DISCONNECT_GRACE_MS=90000
GHOSTFLEET_TURN_TIMEOUT_MS=60000
